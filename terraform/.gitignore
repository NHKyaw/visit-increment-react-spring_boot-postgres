# Local .terraform directory (contains provider binaries/modules)
**/.terraform/*

# .tfstate files (Contains sensitive environment data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (Likely to contain sensitive secrets)
*.tfvars
*.tfvars.json

# Ignore override files 
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include tfplan files to ignore the plan output
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc